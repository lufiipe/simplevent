        "php": "^7.4|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "LuFiipe\\SimplEvent\\": "src/",
            "LuFiipe\\SimplEvent\\Test\\": "tests/"
        }
    },
    "authors": [
